# Server
NODE_ENV=production
APP_ENV=production
PORT=9001

# Frontend URL (used in CORS allowlist)
FRONTEND_URL=https://your-frontend.example.com
BACKEND_URL=https://your-api.example.com

# Cookie security
# Leave COOKIE_SECURE empty to auto-detect:
# - production + non-localhost URLs => secure cookies
# - staging/development/localhost => non-secure cookies over HTTP
COOKIE_SECURE=

# CORS — JSON array of allowed origins
CORS_ORIGIN=["https://your-frontend.example.com"]

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/democore?schema=public

# JWT — generate strong random secrets (e.g. openssl rand -hex 64)
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-strong-secret
JWT_REFRESH_EXPIRES_IN=7d
